# Core runtime
NODE_ENV=development
DISABLE_HMR=false
PORT=3000
ALLOWED_ORIGINS=http://localhost:5173

# Server-side API access (never expose in client bundle)
GEMINI_API_KEY=your_gemini_api_key

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/4real

# Authentication
JWT_SECRET=change_me

# TON network and wallets
NETWORK=mainnet
TONCENTER_API_KEY=your_toncenter_api_key
# 24-word mnemonic for the hot wallet used to sign transactions
HOT_WALLET_MNEMONIC="word1 word2 ... word24"
# Use V4 or V5R1 wallet contract; defaults to V5R1 when unset
HOT_WALLET_VERSION=V5R1
# Base wallet address that receives deposits
HOT_WALLET_ADDRESS=EQXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Jetton wallet address for USDT; required for deposit polling
HOT_JETTON_WALLET=EQYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYY

# Frontend
VITE_TON_MANIFEST_URL=http://localhost:3000/tonconnect-manifest.json
VITE_MERCHANT_MPESA_NUMBER=900 800 700
VITE_MERCHANT_WALLET_ADDRESS=UQAz...8jX2
VITE_MERCHANT_INSTRUCTIONS=Send exact amount and upload screenshot. Merchant release takes 5-30 mins.
