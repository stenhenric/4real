# Required: backend runtime
MONGODB_URI=mongodb://127.0.0.1:27017/4real
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars_for_production

# Required: TON payments and wallet config
NETWORK=mainnet
# Optional but recommended if your Toncenter plan provides one
TONCENTER_API_KEY=
# 24-word mnemonic for the hot wallet used to sign transactions
HOT_WALLET_MNEMONIC="word1 word2 ... word24"
# Optional. Use V4 or V5R1. Defaults to V5R1 when unset.
HOT_WALLET_VERSION=V5R1
# Base wallet address that receives deposits and prepares TonConnect transfers
HOT_WALLET_ADDRESS=EQXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Jetton wallet address for USDT. Required for deposit polling.
HOT_JETTON_WALLET=EQYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYY
# Warn if the hot wallet TON gas reserve drops below this amount.
HOT_WALLET_MIN_TON_BALANCE=1
# Warn if the hot wallet USDT balance drops below this amount.
HOT_WALLET_MIN_USDT_BALANCE=0
# Warn if on-chain USDT and the internal ledger drift by more than this amount.
HOT_WALLET_LEDGER_MISMATCH_TOLERANCE_USDT=1
TELEGRAM_BOT_TOKEN=
TELEGRAM_PROOF_CHANNEL_ID=
PROOF_MAX_BYTES=5242880
PROOF_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp
REDIS_URL=redis://127.0.0.1:6379
FEATURE_DISTRIBUTED_LOCK=false
FEATURE_AGGREGATED_BALANCE_SUM=true
FEATURE_ATOMIC_BALANCE=true
FEATURE_BULLMQ_JOBS=false
FEATURE_REDIS_SOCKET_ADAPTER=false

# Recommended: merchant config served by the backend
MERCHANT_MPESA_NUMBER=900800700
MERCHANT_WALLET_ADDRESS=UQAz...8jX2
MERCHANT_INSTRUCTIONS=Send exact amount and upload screenshot. Merchant release takes 5-30 mins.
MERCHANT_BUY_RATE_KES_PER_USDT=132.5
MERCHANT_SELL_RATE_KES_PER_USDT=128.75

# Optional: legacy frontend merchant fallbacks. Keep only if you still need old VITE_* compatibility.
VITE_MERCHANT_MPESA_NUMBER=900800700
VITE_MERCHANT_WALLET_ADDRESS=UQAz...8jX2
VITE_MERCHANT_INSTRUCTIONS=Send exact amount and upload screenshot. Merchant release takes 5-30 mins.
VITE_MERCHANT_BUY_RATE_KES_PER_USDT=132.5
VITE_MERCHANT_SELL_RATE_KES_PER_USDT=128.75

# Optional: frontend/TonConnect
# Defaults to ${window.location.origin}/tonconnect-manifest.json when unset.
VITE_TON_MANIFEST_URL=http://localhost:3000/tonconnect-manifest.json

# Optional: local server/runtime overrides
# Set explicitly only if you need to override script defaults.
NODE_ENV=development
DISABLE_HMR=false
PORT=3000
# Add every allowed browser origin as a comma-separated list.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
REQUEST_BODY_LIMIT=100kb
GENERAL_RATE_LIMIT_WINDOW_MS=60000
GENERAL_RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_WINDOW_MS=600000
AUTH_RATE_LIMIT_MAX=20
REQUEST_TIMEOUT_MS=30000
KEEP_ALIVE_TIMEOUT_MS=5000
HEADERS_TIMEOUT_MS=60000
WAITING_ROOM_TTL_MS=900000
ACTIVE_ROOM_TTL_MS=3600000
COMPLETED_ROOM_TTL_MS=600000
ROOM_CLEANUP_INTERVAL_MS=60000
MATCH_WAITING_EXPIRY_MS=900000
MATCH_ACTIVE_INACTIVITY_MS=900000
# Optional for deployments behind a reverse proxy or ingress.
TRUST_PROXY=1
