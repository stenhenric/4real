# Use redis:// for local development. Production external Redis must use rediss://.
# Render Key Value internal URLs may be redis:// when the Redis service is in the same Render workspace/region.
REDIS_URL=redis://127.0.0.1:6379
REDIS_CONNECT_TIMEOUT_MS=10000
REDIS_RETRY_BASE_DELAY_MS=250
REDIS_RETRY_MAX_DELAY_MS=5000
# Production topology:
# - single-instance: exactly one Render web instance and WEB_CONCURRENCY=1. Local timers, wallet sends,
#   Socket.IO rooms, and in-memory room state are only safe under this mode.
# - distributed: requires FEATURE_DISTRIBUTED_LOCK=true, FEATURE_BULLMQ_JOBS=true,
#   and FEATURE_REDIS_SOCKET_ADAPTER=true before scaling horizontally.
PRODUCTION_TOPOLOGY=single-instance
# Set explicitly in production deployment metadata if available so startup can fail fast on unsafe scaling.
RENDER_INSTANCE_COUNT=1
WEB_CONCURRENCY=1
FEATURE_DISTRIBUTED_LOCK=false
FEATURE_AGGREGATED_BALANCE_SUM=false
FEATURE_BULLMQ_JOBS=false
FEATURE_REDIS_SOCKET_ADAPTER=false


MERCHANT_MPESA_NUMBER=900800700
MERCHANT_WALLET_ADDRESS=UQAz...8jX2
MERCHANT_INSTRUCTIONS=Send exact amount and upload screenshot. Merchant release takes 5-30 mins.
