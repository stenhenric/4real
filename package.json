{
  "name": "4REAL",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx main.ts",
    "start": "node ./dist/server/main.js",
    "build": "vite build && tsc --project tsconfig.server.json",
    "preview": "vite preview",
    "test": "npm run test:integration",
    "test:unit": "node --import ./server/test/setup-env.js --test --experimental-strip-types server/config/env.test.ts server/services/email/gmail-service.test.ts server/services/auth-email.service.test.ts server/middleware/auth-security.test.ts server/middleware/frontend-contracts.test.ts server/middleware/logging-and-schemas.test.ts server/middleware/migration-services.test.ts server/middleware/security.middleware.test.ts server/middleware/static-files.test.ts",
    "test:integration": "node --import ./server/test/setup-env.js --test --experimental-strip-types server/middleware/*.test.ts",
    "test:e2e": "npm run build && playwright test",
    "test:all": "npm run lint && npm run test:unit && npm run test:integration && npm run test:e2e",
    "gmail:authorize": "tsx scripts/gmail-authorize.ts",
    "docs:architecture": "node scripts/generate-architecture-map.mjs",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "lint": "tsc --noEmit && tsc --project tsconfig.server.json --noEmit",
    "seed": "tsx server/seed.ts",
    "backfill:balance-atomic": "tsx server/scripts/backfill-balance-atomic.ts"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "@tailwindcss/vite": "^4.2.4",
    "@ton/crypto": "^3.3.0",
    "@ton/ton": "^16.2.4",
    "@tonconnect/ui-react": "^2.4.4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.76.3",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-rate-limit": "^8.4.0",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "lucide-react": "^0.546.0",
    "mongoose": "^9.6.1",
    "rate-limit-redis": "^4.3.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.1",
    "roughjs": "^4.6.6",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "uuid": "^14.0.0",
    "vite": "^6.4.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "typescript": "^6.0.3"
  }
}
