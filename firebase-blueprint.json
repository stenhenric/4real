{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with game stats and wallet info",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "tonWallet": { "type": "string" },
        "balance": { "type": "number" },
        "elo": { "type": "number" },
        "isAdmin": { "type": "boolean" }
      },
      "required": ["username", "balance", "elo"]
    },
    "Match": {
      "title": "Match",
      "description": "Connection 4 game session",
      "type": "object",
      "properties": {
        "player1Id": { "type": "string" },
        "player2Id": { "type": "string" },
        "p1Username": { "type": "string" },
        "p2Username": { "type": "string" },
        "winnerId": { "type": "string" },
        "moveHistory": { "type": "array" },
        "status": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["player1Id", "status", "timestamp"]
    },
    "Order": {
      "title": "Order",
      "description": "USDT/Credit trade order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["BUY", "SELL"] },
        "amount": { "type": "number" },
        "proofImageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "DONE", "REJECTED"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "amount", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User document keyed by UID"
    },
    "/matches/{matchId}": {
      "schema": "Match",
      "description": "Match document keyed by matchId"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Trade order keyed by orderId"
    }
  }
}
